{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "bigorangelab/big-orange-pardot",
  "version": "0.1.0",
  "title": "Big Orange Pardot",
  "category": "widgets",
  "icon": "feedback",
  "description": "A WordPress Form block for WordPress to integrate with Pardot.",
  "example": {},
  "supports": {
    "html": false,
    "color": {
      "background": true,
      "text": false
    },
    "spacing": {
      "padding": true,
      "margin": true
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "attributes": {
    "pardotFormUrl": {
      "type": "string",
      "default": ""
    },
    "pardotFormHandlerId": {
      "type": "integer",
      "default": 0
    },
    "fieldLabelColor": {
      "type": "string",
      "default": ""
    },
    "fieldInputBg": {
      "type": "string",
      "default": ""
    },
    "fieldBorderColor": {
      "type": "string",
      "default": ""
    },
    "fieldFocusColor": {
      "type": "string",
      "default": ""
    },
    "fieldBorderRadius": {
      "type": "string",
      "default": ""
    }
  },
  "providesContext": {
    "big-orange-pardot/formUrl": "pardotFormUrl"
  },
  "allowedBlocks": [
    "bigorangelab/pardot-field",
    "bigorangelab/pardot-submit"
  ],
  "textdomain": "big-orange-pardot",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}