{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"preferredVersions": {
		"php": "8.2",
		"wp": "latest"
	},
	"landingPage": "/wp-admin/post-new.php?post_type=page",
	"steps": [
		{
			"step": "login",
			"username": "admin",
			"password": "password"
		},
		{
			"step": "installPlugin",
			"pluginZipFile": {
				"resource": "wordpress.org/plugins",
				"slug": "kadence-blocks"
			}
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "git:directory",
				"url": "https://github.com/BigOrangeLab/big-orange-pardot",
				"ref": "HEAD",
				"refType": "branch"
			},
			"options": {
				"activate": true,
				"targetFolderName": "big-orange-pardot"
			}
		}
	]
}
