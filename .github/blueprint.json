{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"preferredVersions": {
		"php": "8.2",
		"wp": "latest"
	},
	"landingPage": "/",
	"steps": [
		{
			"step": "login",
			"username": "admin",
			"password": "password"
		},
		{
			"step": "installPlugin",
			"pluginZipFile": {
				"resource": "wordpress.org/plugins",
				"slug": "kadence-blocks"
			}
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "git:directory",
				"url": "https://github.com/BigOrangeLab/big-orange-pardot",
				"ref": "main",
				"refType": "branch"
			},
			"options": {
				"activate": true,
				"targetFolderName": "big-orange-pardot"
			}
		},
		{
			"step": "runPHP",
			"code": "<?php require '/wordpress/wp-load.php'; include_once WP_PLUGIN_DIR . '/big-orange-pardot/.github/setup.php';"
		}
	]
}
