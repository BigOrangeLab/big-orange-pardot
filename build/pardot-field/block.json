{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "bigorangelab/pardot-field",
  "version": "1.0.0",
  "title": "Pardot Field",
  "category": "widgets",
  "icon": "edit-page",
  "description": "A single form field inside a Big Orange Pardot form block.",
  "parent": [
    "bigorangelab/pardot-form"
  ],
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "fieldName": {
      "type": "string",
      "default": ""
    },
    "label": {
      "type": "string",
      "default": ""
    },
    "fieldType": {
      "type": "string",
      "default": "text",
      "enum": [
        "text",
        "email",
        "tel",
        "textarea"
      ]
    },
    "isRequired": {
      "type": "boolean",
      "default": false
    },
    "placeholder": {
      "type": "string",
      "default": ""
    },
    "width": {
      "type": "string",
      "default": "full",
      "enum": [
        "full",
        "half"
      ]
    }
  },
  "usesContext": [
    "big-orange-pardot/formUrl"
  ],
  "textdomain": "big-orange-pardot",
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}