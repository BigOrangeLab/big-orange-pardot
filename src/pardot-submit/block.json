{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bigorangelab/pardot-submit",
	"version": "0.1.0",
	"title": "Pardot Submit Button",
	"category": "widgets",
	"icon": "button",
	"description": "The submit button inside a Big Orange Pardot form block.",
	"parent": [ "bigorangelab/big-orange-pardot" ],
	"supports": {
		"html": false,
		"reusable": false,
		"spacing": {
			"margin": true
		}
	},
	"attributes": {
		"label": {
			"type": "string",
			"default": "Submit"
		},
		"buttonTextColor": {
			"type": "string",
			"default": ""
		},
		"buttonBgColor": {
			"type": "string",
			"default": ""
		},
		"buttonBgGradient": {
			"type": "string",
			"default": ""
		},
		"buttonHoverBgColor": {
			"type": "string",
			"default": ""
		},
		"buttonBorderColor": {
			"type": "string",
			"default": ""
		},
		"buttonBorderWidth": {
			"type": "string",
			"default": ""
		},
		"buttonBorderStyle": {
			"type": "string",
			"default": ""
		},
		"buttonBorderRadius": {
			"type": "string",
			"default": ""
		},
		"buttonPadding": {
			"type": "object",
			"default": {}
		},
		"buttonShadow": {
			"type": "string",
			"default": ""
		},
		"buttonAlignment": {
			"type": "string",
			"default": "left"
		}
	},
	"textdomain": "big-orange-pardot",
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
